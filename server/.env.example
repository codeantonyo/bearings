# Local dev works with NO configuration — it uses an in-process PGlite database
# and stores uploaded photos in server/uploads/. Copy to server/.env only if you
# want to override defaults.

PORT=4000
# Use a long random string in production (e.g. `openssl rand -base64 32`).
JWT_SECRET=change-me-to-a-long-random-string

# Pre-seeded admin account (created on first run if it doesn't exist).
ADMIN_EMAIL=admin@becobearings.com
ADMIN_PASSWORD=beco-admin-2026

# --- Production (Vercel) — set these in the Vercel dashboard, not here ---
# Hosted Postgres (Neon / Vercel Postgres). If set, it is used instead of PGlite.
# DATABASE_URL=postgres://user:pass@host/db?sslmode=require
# Vercel Blob (auto-populated when you link a Blob store to the project).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxx
