# Copy to .env and adjust. Sensible defaults are used if this file is absent.
PORT=4000
# Use a long random string in production (e.g. `openssl rand -base64 32`).
JWT_SECRET=change-me-to-a-long-random-string
# Pre-seeded admin account (created on first run if it doesn't exist)
ADMIN_EMAIL=admin@becobearings.com
ADMIN_PASSWORD=beco-admin-2026
# Where the client runs (for CORS). In production set this to your frontend URL,
# e.g. https://beco-bearings.vercel.app
CLIENT_ORIGIN=http://localhost:5173
